language ESSENCE' 1.0

$ ----- PARAMETERS -------------------------
given vertices : int(1..)
given colours : int(1..)
given edge_count : int(1..)

letting VERTICES be domain int(1..vertices)
letting COLOURS be domain int(1..colours)
letting EDGES be domain int(1..edge_count)

given edges : matrix indexed by [EDGES,int(1..2)] of VERTICES


$ ----- VARIABLES --------------------------
find colouring : matrix indexed by [VERTICES] of COLOURS
find usedColours : COLOURS

$ ----- OBJECTIVE --------------------------
minimising usedColours

$ ----- CONSTRAINTS ------------------------
such that 
   
   forall e : EDGES.
        colouring[edges[e,1]] != colouring[edges[e,2]],

   forall a : VERTICES .
        usedColours >= colouring[a]
